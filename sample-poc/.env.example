# ─────────────────────────────────────────────────────────────
# POC: Rust-Accelerated End-to-End Lakehouse — environment
# Copy to `.env` and adjust. NEVER commit the real `.env`.
# ─────────────────────────────────────────────────────────────

# --- Image tags (PIN these; verify they exist on first `docker compose pull`) ---
POSTGRES_IMAGE=postgres:16-alpine
MINIO_IMAGE=minio/minio:latest
MC_IMAGE=minio/mc:latest
LAKEKEEPER_IMAGE=quay.io/lakekeeper/catalog:latest
TRINO_IMAGE=trinodb/trino:468

# --- MinIO (object store / S3) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_BUCKET=warehouse
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1

# --- Shared metadata Postgres (hosts: lakekeeper, later airflow, superset DBs) ---
META_DB_USER=postgres
META_DB_PASSWORD=postgres
META_DB_NAME=postgres
# Lakekeeper logical DB on the shared meta-db
LAKEKEEPER_DB=lakekeeper
# 32-byte secret used by Lakekeeper to encrypt stored storage credentials.
# Generate a real one: `openssl rand -base64 32`
LAKEKEEPER_PG_ENCRYPTION_KEY=change-me-please-32-bytes-minimum

# --- Lakekeeper warehouse registered via bootstrap (see infra/lakekeeper/bootstrap.sh) ---
LAKEKEEPER_WAREHOUSE=warehouse

# --- Source OLTP Postgres (synthetic e-commerce data, Phase 2) ---
SOURCE_DB_USER=source
SOURCE_DB_PASSWORD=source
SOURCE_DB_NAME=ecommerce

# --- Full-profile services (Airflow + Superset; Phases 5-6) ---
# Generate real secrets: `openssl rand -hex 32` and (fernet) `python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"`
AIRFLOW_FERNET_KEY=change-me-fernet-key
SUPERSET_SECRET_KEY=change-me-superset-secret-key
