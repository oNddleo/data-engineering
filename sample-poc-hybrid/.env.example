# =====================================================================
# Hybrid Lakehouse POC — pinned versions
# Copy to .env: cp .env.example .env
# =====================================================================

COMPOSE_PROJECT_NAME=hybrid

# --- Image pins ------------------------------------------------------
SPARK_IMAGE_TAG=4.0.0
DELTA_VERSION=4.0.0
SCALA_BINARY=2.13
HADOOP_AWS_VERSION=3.4.1
AWS_SDK_BUNDLE_VERSION=1.12.770

KAFKA_IMAGE=apache/kafka:4.0.0
KAFKA_UI_IMAGE=provectuslabs/kafka-ui:v0.7.2

MINIO_IMAGE=minio/minio:RELEASE.2025-04-22T22-12-26Z
MINIO_MC_IMAGE=minio/mc:RELEASE.2025-04-22T17-50-53Z

POSTGRES_IMAGE=postgres:17-alpine

UC_IMAGE=unitycatalog/unitycatalog:0.3.0
HMS_IMAGE=apache/hive:4.0.0

TRINO_IMAGE=trinodb/trino:470

AIRFLOW_IMAGE_TAG=3.0.6
SUPERSET_IMAGE=apache/superset:4.1.2

# --- Host ports (offset +5 vs sample-poc) ----------------------------
PORT_SPARK_MASTER_UI=8081
PORT_SPARK_MASTER=7077
PORT_KAFKA_CLIENT=9092
PORT_KAFKA_UI=8090
PORT_MINIO_API=9000
PORT_MINIO_CONSOLE=9001
PORT_PG_META=5433
PORT_PG_OLTP=5434
PORT_UC=8087
PORT_HMS=9083
PORT_TRINO=8085
PORT_AIRFLOW=8086
PORT_SUPERSET=8089

# --- Resources -------------------------------------------------------
SPARK_WORKER_MEMORY=2G
SPARK_WORKER_CORES=2

# --- Credentials (POC only — change in real deploy) ------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_BUCKET=lakehouse
S3_ENDPOINT_URL=http://minio:9000

PG_META_USER=metauser
PG_META_PASSWORD=metapass
PG_META_DB=metastore
PG_AIRFLOW_DB=airflow
PG_UC_DB=ucatalog

PG_OLTP_USER=oltpuser
PG_OLTP_PASSWORD=oltppass
PG_OLTP_DB=devices

# --- Airflow ---------------------------------------------------------
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# --- Superset --------------------------------------------------------
SUPERSET_SECRET_KEY=change-me-in-real-deploy-please-32-bytes-minimum
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin

# --- Kafka KRaft -----------------------------------------------------
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
# Generate fresh ID with: docker run --rm apache/kafka:4.0.0 /opt/kafka/bin/kafka-storage.sh random-uuid
