# BLS API key (optional; unregistered calls are rate-limited to 25/day)
# Register at https://data.bls.gov/registrationEngine/
IC_BLS_API_KEY=

# Optional: enable a local Ollama server as the LLM fallback for pages where
# JSON-LD / microdata / OpenGraph / heuristic extractors come up empty.
# Run `ollama serve && ollama pull llama3.2:3b` first.
IC_OLLAMA_ENABLED=false
IC_OLLAMA_HOST=http://127.0.0.1:11434
IC_OLLAMA_MODEL=llama3.2:3b

IC_DATA_DIR=./data
IC_DB_PATH=./data/inflation.duckdb
IC_FETCH_CONCURRENCY=16
